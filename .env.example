# Core server
PORT=5100
LAW_ACTIVATION_SECRET_KEY=replace-with-a-long-random-secret
USERS_DB_FILE=/tmp/users.json
CODES_DB_FILE=/tmp/codes.json

# Qdrant Cloud: required for Render Free deployment
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=law_articles_qwen4b_full

# Local fallback only, not used when QDRANT_URL is set
INDEX_STORAGE_DIR=rag/storage_full
QDRANT_LOCAL_PATH=rag/storage_full/qdrant_local

# SiliconFlow: embeddings + rerank
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
SILICONFLOW_RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
SILICONFLOW_ENABLE_RERANK=1
SILICONFLOW_EMBED_BATCH_SIZE=64
SILICONFLOW_REQUEST_BATCH_SIZE=16
SILICONFLOW_MAX_PARALLEL_REQUESTS=4

# DeepSeek: Agent + query analysis + evidence compression
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_QUERY_ANALYSIS_MODEL=deepseek-chat
