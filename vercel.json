{
    "version": 2,
    "builds": [
        {
            "src": "auth_server.py",
            "use": "@vercel/python"
        },
        {
            "src": "**/*.{html,js,css,json,png,jpg,gif,svg,xlsx}",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(register|login|redeem|change_password)",
            "dest": "auth_server.py"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "index.html"
        }
    ]
}